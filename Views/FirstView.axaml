<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Assignment3.ViewModels"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Assignment3.Views.FirstView"
             x:DataType="vm:FirstViewModel">

             
 <Grid RowDefinitions="Auto,*">
    <StackPanel Grid.Row="0">
        <!-- buttons, Searching, etc -->
         <TextBlock Text="{Binding Greeting}" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="15" Margin="20"/>
    </StackPanel>
 
 <mapsui:MapControl Grid.Row="1" Map="{Binding Map}" />
</Grid>
</UserControl>
